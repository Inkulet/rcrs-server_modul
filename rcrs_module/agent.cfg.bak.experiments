[logging]

# enabled = false, отключение всех логов агентов.
# level принимает: DEBUG, INFO, WARNING, ERROR, CRITICAL
# log_dir — каталог, куда складываются все файлы логов и метрик.
#   Путь абсолютный; по умолчанию — <project_root>/log.

enabled = false
level = WARNING
log_dir = /Users/glebpashkov/rcrs_diplom/log

[metrics]

# enabled = false отключает time.md и классические агрегированные замеры.
# budget_ms — бюджет на матмодель (utility) за такт, превышения считаются
#   как over_budget в сводке.
# report_period — каждые N тактов перезаписывается time.md.
# file — имя отчёта внутри log_dir.

enabled = false
budget_ms = 100.0
report_period = 25
file = time.md

[csv_metrics]

# Детализированные CSV/JSON-сборки метрик для ablation/диагностики.
# Каждый тумблер независим, все файлы пишутся в log_dir.
#
# tick_csv_enabled — per-tick, per-agent строка со всеми фазами/воронкой
#   задач/разложением utility/флагами событий.
#   Имя файла: tick_<AGENT_TYPE>_<pid>.csv
# events_csv_enabled — per-event лог (target_change, stuck, freeze,
#   communication). Имя: events_<AGENT_TYPE>_<pid>.csv
# summary_json_enabled — финальный per-agent summary.json на конец
#   сессии (счётчики, freeze_rate, трафик). Имя: summary_<AGENT_TYPE>_<pid>.json

tick_csv_enabled = false
events_csv_enabled = false
summary_json_enabled = false

[communication]

# radio_enabled = false полностью отключает радио-связь:
# агенты не отправляют AKSay и игнорируют входящие hearing/claims.
# Это удобно для честных ablation-прогонов без coordination-layer.

radio_enabled = false

[weights]

# Опциональный оверрайд весов матмодели. Формат: "w_c,w_d,w_e,w_n"
# (сумма должна быть 1.0). Пустое значение → использовать значения
# по умолчанию, зашитые в agent/{fire,ambulance,police}.py.
# Используется experiment-runner-ом для ablation-прогонов.

fire =
ambulance =
police =

[run_table]

# enabled = true — после прогона tools/finalize_run.py сканирует log_dir
# и добавляет одну строку в сводную таблицу. Столбцы Map / ADF Score /
# Наш Score / Δ % заполняются «?», чтобы я вписал вручную. Остальные
# поля (freeze %, t_total p95, t_util mean, peak_density, Gini)
# собираются автоматически из summary_*.json и tick_*.csv.
# file — имя сводной таблицы внутри log_dir.

enabled = false
file = runs.md
